# =============================================================================
# Database
# =============================================================================
PG_USER=authentik
PG_PASS=            # openssl rand -base64 32
PG_DB=authentik

# =============================================================================
# Redis
# =============================================================================
REDIS_PASS=         # openssl rand -base64 48

# =============================================================================
# Authentik
# =============================================================================
AUTHENTIK_SECRET_KEY=  # openssl rand -base64 60

# =============================================================================
# Let's Encrypt
# =============================================================================
ACME_EMAIL=         # your-email@example.com

# =============================================================================
# Domain
# =============================================================================
AUTHENTIK_DOMAIN=   # auth.yourdomain.com
TRAEFIK_DOMAIN=     # traefik.yourdomain.com

# =============================================================================
# SMTP Relay (IONOS or other provider)
# =============================================================================
SMTP_RELAY_HOST=    # smtp.ionos.de
SMTP_RELAY_PORT=    # 587
SMTP_RELAY_USER=    # noreply@yourdomain.com
SMTP_RELAY_PASS=    # your-smtp-password

# =============================================================================
# Traefik Dashboard
# =============================================================================
# Generate with: htpasswd -nb admin <password>
# Then paste the full output here (e.g. admin:$apr1$xxxx$yyyy)
TRAEFIK_DASHBOARD_AUTH=