#!/bin/bash
# =============================================================================
# Pre-commit hook: Scan staged files for accidental secret/credential leaks.
# Install: git config core.hooksPath .githooks
# Bypass:  git commit --no-verify
# =============================================================================
set -euo pipefail

RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

SECRETS_FOUND=0

# Only check staged files
STAGED=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || true)

if [ -z "$STAGED" ]; then
    exit 0
fi

for FILE in $STAGED; do
    # Skip binary and lock files
    case "$FILE" in
        *.png|*.jpg|*.gif|*.svg|*.ico|*.woff2|*.woff|*.ttf|*.eot|*.db|*.sqlite) continue ;;
        package-lock.json|yarn.lock) continue ;;
    esac

    # Skip files that don't exist (deleted)
    [ ! -f "$FILE" ] && continue

    # Skip .env.example (placeholder values only)
    [ "$FILE" = ".env.example" ] && continue

    # Get the staged content of the file
    CONTENT=$(git show ":$FILE" 2>/dev/null || cat "$FILE")

    # ---- Check: Private keys ----
    if echo "$CONTENT" | grep -qP -- '-----BEGIN (RSA |EC |DSA |OPENSSH )?PRIVATE KEY-----'; then
        echo -e "${RED}SECRET DETECTED${NC} in ${FILE}: private key found"
        SECRETS_FOUND=1
    fi

    # ---- Check: Password/secret/token assignments ----
    # Excludes: placeholders, empty values, variable references, shell commands like $(openssl rand)
    MATCHES=$(echo "$CONTENT" | grep -nP '(PASSWORD|SECRET|TOKEN|API_KEY|PRIVATE_KEY|ACCESS_KEY|PASS)\s*=\s*\S{8,}' 2>/dev/null \
        | grep -vP '=\s*(CHANGE_ME|""|'"''"'\s*$|\$\{?\w+\}?|openssl\.rand|your-|example|placeholder|#|\$\()' || true)
    if [ -n "$MATCHES" ]; then
        echo -e "${RED}SECRET DETECTED${NC} in ${FILE}:"
        echo "$MATCHES" | while read -r line; do
            echo "  $line"
        done
        SECRETS_FOUND=1
    fi

    # ---- Check: Connection strings with embedded passwords ----
    MATCHES=$(echo "$CONTENT" | grep -nP '(postgres|mysql|mongodb|redis)://[^\s:]+:[^\s@]+@' 2>/dev/null || true)
    if [ -n "$MATCHES" ]; then
        echo -e "${RED}SECRET DETECTED${NC} in ${FILE}: connection string with embedded password"
        SECRETS_FOUND=1
    fi

    # ---- Check: AWS-style access keys ----
    MATCHES=$(echo "$CONTENT" | grep -nP 'AKIA[0-9A-Z]{16}' 2>/dev/null || true)
    if [ -n "$MATCHES" ]; then
        echo -e "${RED}SECRET DETECTED${NC} in ${FILE}: AWS access key"
        SECRETS_FOUND=1
    fi

    # ---- Check: htpasswd / bcrypt hashes ----
    MATCHES=$(echo "$CONTENT" | grep -nP '\$apr1\$[^\s]+|\$2[by]?\$[0-9]{2}\$[^\s]+' 2>/dev/null || true)
    if [ -n "$MATCHES" ]; then
        echo -e "${RED}SECRET DETECTED${NC} in ${FILE}: password hash"
        SECRETS_FOUND=1
    fi

    # ---- Check: High-entropy strings (40+ base64 chars) ----
    # Warn-only, not blocked. Skip variable refs, templates, and shell generators.
    MATCHES=$(echo "$CONTENT" | grep -nP '[A-Za-z0-9+/]{40,}={0,2}' 2>/dev/null \
        | grep -vP '\$\{?\w+\}?|placeholder|example|CHANGE_ME|template|openssl\.rand|\$\(' || true)
    if [ -n "$MATCHES" ]; then
        echo -e "${YELLOW}SUSPICIOUS${NC} in ${FILE}: high-entropy string (check if it's a secret)"
        echo "$MATCHES" | while read -r line; do
            echo "  $line"
        done
    fi
done

if [ "$SECRETS_FOUND" -eq 1 ]; then
    echo ""
    echo -e "${YELLOW}Possible secrets found in staged files.${NC}"
    echo "If these are false positives, commit with: git commit --no-verify"
    echo ""
    exit 1
fi

exit 0